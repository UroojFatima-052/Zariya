# ─────────────────────────────────────────
#  Zariya — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────

# App
SECRET_KEY=your-long-random-secret-key-here

# Database
# Leave blank for local SQLite (auto-created as zariya.db)
# For production (Railway/Render), paste the PostgreSQL URL they provide
DATABASE_URL=

# Admin account (created automatically on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe@123

# ─────────────────────────────────────────
#  Email — Brevo SMTP (free: 300 emails/day)
#  Setup:
#    1. Sign up free at brevo.com
#    2. Go to SMTP & API → generate an SMTP key
#    3. Go to Senders & IPs → add and verify your sender email
#    4. Fill in the credentials below
# ─────────────────────────────────────────
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-brevo-smtp-username
MAIL_PASSWORD=your-brevo-smtp-password
MAIL_DEFAULT_SENDER=Zariya <your-verified-sender@example.com>
